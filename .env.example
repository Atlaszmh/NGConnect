# Sonarr
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key

# Radarr
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key

# SABnzbd
SABNZBD_URL=http://localhost:8080
SABNZBD_API_KEY=your_sabnzbd_api_key

# NZBGeek
NZBGEEK_URL=https://api.nzbgeek.info
NZBGEEK_API_KEY=your_nzbgeek_api_key

# Authentication (optional - leave empty to skip auth)
# Generate a password hash: cd server && npx tsx -e "import bcrypt from 'bcryptjs'; bcrypt.hash('yourpassword', 10).then(console.log)"
AUTH_USERNAME=
AUTH_PASSWORD_HASH=

# JWT Secret (change this to a random string)
JWT_SECRET=change-me-to-a-random-string

# Logging
LOG_LEVEL=info
